PROJECTS_ROOT=/projects
PROJECTS_ROOTS=/projects,/workspace/projects
ENABLE_HTTP=true
ENABLE_STDIO=true
ENABLE_OTEL=false
OTEL_SERVICE_NAME=coding-mcp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=
ENABLE_AUTH=false
AUTH_HEADER_NAME=x-api-key
AUTH_API_KEYS=
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
HTTP_MODE=streamable
MAX_FILE_SIZE=1048576
MAX_OUTPUT_SIZE=131072
COMMAND_TIMEOUT_MS=120000
ALLOWED_COMMANDS=npm,pnpm,yarn,go,python,pytest,php,composer,make
PROTECTED_PATHS=.git,.env,.env.local,.env.production
LOG_LEVEL=info
REGISTRY_FILE=~/.coding-mcp/registry.json
AUDIT_LOG_FILE=~/.coding-mcp/audit.log
DEBUG_MODE=false
