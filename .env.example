# This is an example .env file for the Coding MCP (Model Context Protocol).
# Copy this file to .env and customize the values as needed for your environment.


# Root directory for projects. This is where the MCP will look for projects to manage.
# You can specify multiple directories by separating them with commas.
PROJECTS_ROOT=/projects
PROJECTS_ROOTS=/projects,/workspace/projects

# Enable or disable the HTTP server. Set to true to enable, false to disable.
# When enabled, the MCP will listen for HTTP requests on the specified host and port.
# If disabled, the MCP will only operate in stdio mode, which is useful for integration with other tools.
ENABLE_HTTP=true
ENABLE_STDIO=true

# Enable or disable OpenTelemetry (OTEL) for tracing. Set to true to enable, false to disable.
ENABLE_OTEL=false
OTEL_SERVICE_NAME=coding-mcp
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=

# Enable or disable authentication for the HTTP server. Set to true to enable, false to disable.
# When enabled, the MCP will require clients to provide a valid API key in the specified header for authentication.
# You can specify multiple API keys by separating them with commas. For example: "key1,key2,key3".
ENABLE_AUTH=false
AUTH_HEADER_NAME=x-api-key
AUTH_API_KEYS=

# HTTP server configuration
# The MCP will listen for HTTP requests on the specified host and port. You can customize the host and port as needed.
# The HTTP_MODE setting determines how the MCP handles HTTP requests. The "streamable" mode allows for streaming responses, which is useful for long-running commands or commands that produce a lot of output. The "buffered" mode buffers the entire response before sending it to the client, which can be more efficient for short commands with small output.
HTTP_HOST=127.0.0.1
HTTP_PORT=3000
HTTP_MODE=streamable

# Command execution settings
MAX_FILE_SIZE=1048576
MAX_OUTPUT_SIZE=131072
COMMAND_TIMEOUT_MS=120000
RETRY_MAX_ATTEMPTS=2
RETRY_BASE_DELAY_MS=200
ALLOWED_COMMANDS=npm,pnpm,yarn,go,python,pytest,ruff,flake8,cargo,mvn,gradle,php,composer,phpunit,make
PROTECTED_PATHS=.git,.env,.env.local,.env.production

# Logging and debugging settings
LOG_LEVEL=info

# File paths for registry, audit log, and HTTP request log. You can customize these paths as needed. The MCP will create these files if they do not exist.
# Make sure the directories for these files exist and are writable by the MCP process.
REGISTRY_FILE=~/.coding-mcp/registry.json
AUDIT_LOG_FILE=~/.coding-mcp/audit.log
HTTP_REQUEST_LOG_FILE=~/.coding-mcp/http-requests.log

# Enable or disable debug mode. When enabled, the MCP will log additional debug information, 
# which can be helpful for troubleshooting and development. Set to true to enable, false to disable.
# Note that enabling debug mode may produce a large amount of log output, 
# so it is recommended to use it only when necessary.
DEBUG_MODE=false
