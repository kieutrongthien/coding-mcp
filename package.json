{
  "name": "@kieutrongthien/coding-mcp",
  "version": "1.0.1",
  "description": "Production-ready multi-project MCP server for coding agents",
  "keywords": ["MCP", "coding", "server", "multi-project", "agents"],
  "type": "module",
  "main": "dist/src/main/stdio.js",
  "bin": {
    "coding-mcp": "dist/src/main/cli.js"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev:serve": "tsx src/main/cli.ts",
    "dev:stdio": "tsx src/main/stdio.ts",
    "dev:http": "tsx src/main/http.ts",
    "start:serve": "node dist/src/main/cli.js",
    "start:stdio": "node dist/src/main/stdio.js",
    "start:http": "node dist/src/main/http.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@modelcontextprotocol/sdk": "^1.13.2",
    "fast-glob": "^3.3.3",
    "mime-types": "^2.1.35",
    "pino": "^9.7.0",
    "undici": "^7.13.0",
    "yaml": "^2.8.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.17",
    "eslint": "^9.26.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
