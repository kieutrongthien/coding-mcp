{
  "name": "@kieutrongthien/coding-mcp",
  "version": "1.0.8",
  "description": "Production-ready multi-project MCP server for coding agents",
  "keywords": [
    "MCP",
    "coding",
    "server",
    "multi-project",
    "agents"
  ],
  "type": "module",
  "main": "dist/src/main/stdio.js",
  "bin": {
    "coding-mcp": "dist/src/main/cli.js"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx --env-file=.env src/main/cli.ts",
    "dev:serve": "tsx --env-file=.env src/main/cli.ts serve",
    "dev:http": "tsx --env-file=.env src/main/cli.ts serve --transport http",
    "dev:stdio": "tsx --env-file=.env src/main/cli.ts serve --transport stdio",
    "start": "node --env-file=.env dist/src/main/cli.js",
    "start:serve": "node --env-file=.env dist/src/main/cli.js serve",
    "start:http": "node --env-file=.env dist/src/main/cli.js serve --transport http",
    "start:stdio": "node --env-file=.env dist/src/main/cli.js serve --transport stdio",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.2",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.2",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "fast-glob": "^3.3.3",
    "mime-types": "^2.1.35",
    "pino": "^9.7.0",
    "pino-pretty": "^13.1.3",
    "undici": "^7.13.0",
    "yaml": "^2.8.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.17",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.26.0",
    "globals": "^17.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.1.2"
  }
}
