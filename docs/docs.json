{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Coding MCP",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/vi",
      "destination": "/vi/index"
    },
    {
      "source": "/vi/",
      "destination": "/vi/index"
